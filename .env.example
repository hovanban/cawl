# Database (SQLite for dev, switch to postgresql:// for production)
DATABASE_URL="file:./dev.db"

# Anthropic AI
ANTHROPIC_API_KEY="sk-ant-..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

